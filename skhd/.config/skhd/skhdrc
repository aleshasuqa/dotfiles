# change window focus within space
cmd - j : yabai -m window --focus south
cmd - k : yabai -m window --focus north
cmd - h : yabai -m window --focus west
cmd - l : yabai -m window --focus east

#change focus between external displays (left and right)
alt - s: yabai -m display --focus west
alt - g: yabai -m display --focus east

# rotate layout clockwise
cmd + shift - r : yabai -m space --rotate 270

# flip along y-axis
cmd + shift - y : yabai -m space --mirror y-axis

# flip along x-axis
cmd + shift - x : yabai -m space --mirror x-axis

# toggle window float
cmd + shift - f : yabai -m window --toggle float --grid 4:4:1:1:2:2

# maximize a window
cmd + shift - m : yabai -m window --toggle zoom-fullscreen

# balance out tree of windows (resize to occupy same area)
cmd + shift - e : yabai -m space --balance

# swap windows
cmd + shift - j : yabai -m window --swap south
cmd + shift - k : yabai -m window --swap north
cmd + shift - h : yabai -m window --swap west
cmd + shift - l : yabai -m window --swap east

# move window and split
cmd + alt - j : yabai -m window --warp south
cmd + alt - k : yabai -m window --warp north
cmd + alt - h : yabai -m window --warp west
cmd + alt - l : yabai -m window --warp east

# resize
ctrl + shift + cmd - h : yabai -m window --resize left:-20:0 ; yabai -m window --resize right:-20:0
ctrl + shift + cmd - j : yabai -m window --resize bottom:0:20 ; yabai -m window --resize top:0:20
ctrl + shift + cmd - k : yabai -m window --resize top:0:-20 ; yabai -m window --resize bottom:0:-20
ctrl + shift + cmd - l : yabai -m window --resize right:20:0 ; yabai -m window --resize left:20:0

# move window to display left and right
shift + alt - s : yabai -m window --display west; yabai -m display --focus west;
shift + alt - g : yabai -m window --display east; yabai -m display --focus east;

#move window to prev and next space
shift + alt - p : yabai -m window --space prev;
shift + alt - n : yabai -m window --space next;

# move window to space #
cmd + shift - 1 : yabai -m window --space 1;
cmd + shift - 2 : yabai -m window --space 2;
cmd + shift - 3 : yabai -m window --space 3;
cmd + shift - 4 : yabai -m window --space 4;
cmd + shift - 5 : yabai -m window --space 5;
cmd + shift - 6 : yabai -m window --space 6;
cmd + shift - 7 : yabai -m window --space 7;


# focus window to space #
cmd - 1 : yabai -m space --focus 1;
cmd - 2 : yabai -m space --focus 2;
cmd - 3 : yabai -m space --focus 3;
cmd - 4 : yabai -m space --focus 4;
cmd - 5 : yabai -m space --focus 5;
cmd - 6 : yabai -m space --focus 6;
cmd - 7 : yabai -m space --focus 7;

# drugoe
cmd + ctrl - return : open /Applications/kitty
cmd + shift - q : open -b com.apple.ScreenSaver.Engine
